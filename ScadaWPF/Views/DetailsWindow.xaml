<Window x:Class="ScadaWPF.Views.DetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:ScadaWPF.Converters"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Tag Details" Height="650" Width="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource MaterialDesignPaper}"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        FontFamily="{materialDesign:MaterialDesignFont}">

    <Window.Resources>
        <conv:AlarmStateToColorConverter x:Key="AlarmColorConverter"/>
        <conv:BoolToYesNoConverter       x:Key="BoolYesNo"/>

        <!-- Stil za naziv polja -->
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="Foreground" Value="{DynamicResource MaterialDesignBodyLight}"/>
            <Setter Property="Margin"     Value="0,0,0,2"/>
        </Style>

        <!-- Stil za vrednost polja -->
        <Style x:Key="FieldValue" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="13"/>
            <Setter Property="Foreground" Value="{DynamicResource MaterialDesignBody}"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Margin"     Value="0,0,0,10"/>
        </Style>
    </Window.Resources>

    <DockPanel Margin="24">

        <!-- Zaglavlje -->
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,16">
            <TextBlock x:Name="TxtTitle" FontSize="18" FontWeight="Medium"/>
        </StackPanel>

        <!-- Dugme za zatvaranje -->
        <Button DockPanel.Dock="Bottom" Content="Close"
                Style="{StaticResource SecondaryButton}"
                HorizontalAlignment="Right" Width="90" Margin="0,16,0,0"
                Click="BtnClose_Click"/>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- Kartica sa parametrima taga -->
                <materialDesign:Card Padding="16,14" Margin="0,0,0,16"
                                      UniformCornerRadius="4"
                                      materialDesign:ElevationAssist.Elevation="Dp1">
                    <Grid x:Name="GridParams">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Leva kolona -->
                        <StackPanel Grid.Column="0" Margin="0,0,12,0">
                            <TextBlock Style="{StaticResource FieldLabel}" Text="Name"/>
                            <TextBlock x:Name="ValName"        Style="{StaticResource FieldValue}"/>

                            <TextBlock Style="{StaticResource FieldLabel}" Text="Type"/>
                            <TextBlock x:Name="ValType"        Style="{StaticResource FieldValue}"/>

                            <TextBlock Style="{StaticResource FieldLabel}" Text="Description"/>
                            <TextBlock x:Name="ValDescription" Style="{StaticResource FieldValue}"
                                       TextWrapping="Wrap"/>

                            <TextBlock Style="{StaticResource FieldLabel}" Text="I/O Address"/>
                            <TextBlock x:Name="ValAddress"     Style="{StaticResource FieldValue}"/>
                        </StackPanel>

                        <!-- Desna kolona -->
                        <StackPanel Grid.Column="1">
                            <!-- Polja samo za ulazne tagove -->
                            <StackPanel x:Name="PanelScan">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="Scan Time (ms)"/>
                                <TextBlock x:Name="ValScanTime"    Style="{StaticResource FieldValue}"/>

                                <TextBlock Style="{StaticResource FieldLabel}" Text="Scanning"/>
                                <TextBlock x:Name="ValScanEnabled" Style="{StaticResource FieldValue}"/>
                            </StackPanel>

                            <!-- Polja samo za analogne tagove -->
                            <StackPanel x:Name="PanelAnalog">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="Low Limit"/>
                                <TextBlock x:Name="ValLow"   Style="{StaticResource FieldValue}"/>

                                <TextBlock Style="{StaticResource FieldLabel}" Text="High Limit"/>
                                <TextBlock x:Name="ValHigh"  Style="{StaticResource FieldValue}"/>

                                <TextBlock Style="{StaticResource FieldLabel}" Text="Units"/>
                                <TextBlock x:Name="ValUnits" Style="{StaticResource FieldValue}"/>
                            </StackPanel>

                            <!-- Polja samo za AI -->
                            <StackPanel x:Name="PanelAiOnly">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="Deadband"/>
                                <TextBlock x:Name="ValDeadband"   Style="{StaticResource FieldValue}"/>

                                <TextBlock Style="{StaticResource FieldLabel}" Text="Hysteresis"/>
                                <TextBlock x:Name="ValHysteresis" Style="{StaticResource FieldValue}"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </materialDesign:Card>

                <!-- Sekcija alarma (samo za AI) -->
                <StackPanel x:Name="PanelAlarms">
                    <TextBlock Text="Alarms" FontSize="15" FontWeight="Medium"
                               Foreground="{StaticResource DangerBrush}" Margin="0,0,0,8"/>

                    <ListView x:Name="AlarmList"
                              FontSize="12" MaxHeight="180"
                              materialDesign:DataGridAssist.ColumnHeaderPadding="10,6,10,6"
                              PreviewMouseDown="AlarmList_PreviewMouseDown">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem"
                                   BasedOn="{StaticResource MaterialDesignGridViewItem}">
                                <!-- Boja pozadine prema stanju alarma -->
                                <Setter Property="Background"
                                        Value="{Binding State,
                                            Converter={StaticResource AlarmColorConverter}}"/>
                                <Style.Triggers>
                                    <!-- Kad je selektovan: zadrži boju alarma, samo dodaj okvir -->
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="BorderBrush" Value="{DynamicResource PrimaryHueMidBrush}"/>
                                        <Setter Property="BorderThickness" Value="1"/>
                                    </Trigger>
                                    <!-- Hover: blago zatamni, ne menjaj boju alarma -->
                                    <MultiTrigger>
                                        <MultiTrigger.Conditions>
                                            <Condition Property="IsMouseOver" Value="True"/>
                                            <Condition Property="IsSelected" Value="False"/>
                                        </MultiTrigger.Conditions>
                                        <Setter Property="Opacity" Value="0.85"/>
                                    </MultiTrigger>
                                </Style.Triggers>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.View>
                            <GridView ColumnHeaderContainerStyle="{StaticResource CompactGridViewColumnHeader}">
                                <GridViewColumn Header="ID"      Width="55"
                                                DisplayMemberBinding="{Binding Id}"/>
                                <GridViewColumn Header="Message" Width="140"
                                                DisplayMemberBinding="{Binding Message}"/>
                                <GridViewColumn Header="Limit"   Width="70"
                                                DisplayMemberBinding="{Binding Limit}"/>
                                <GridViewColumn Header="Direction" Width="90">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock>
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="Low"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsHighAlarm}" Value="True">
                                                                <Setter Property="Text" Value="High"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="State"   Width="100"
                                                DisplayMemberBinding="{Binding State}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>

                    <!-- Dugmad za akcije nad alarmom -->
                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                        <Button Content="✓ Acknowledge"
                                Style="{StaticResource SecondaryButton}"
                                Margin="0,0,8,0" Click="BtnAck_Click"/>
                        <Button Content="✎ Update Alarm"
                                Style="{StaticResource SecondaryButton}"
                                Margin="0,0,8,0" Click="BtnUpdateAlarm_Click"/>
                        <Button Content="✕ Delete Alarm"
                                Style="{StaticResource DangerButton}"
                                Click="BtnDeleteAlarm_Click"/>
                    </StackPanel>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
