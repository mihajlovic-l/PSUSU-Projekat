<Window x:Class="ScadaWPF.Views.AddWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Add Tag / Alarm" Height="560" Width="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource MaterialDesignPaper}"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        FontFamily="{materialDesign:MaterialDesignFont}">

    <DockPanel Margin="24">

        <!-- Zaglavlje prozora -->
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,16">
            <TextBlock Text="Add Tag / Alarm"
               FontSize="17" FontWeight="Medium"/>
        </StackPanel>

        <!-- Izbor tipa (AI/AO/DI/DO/Alarm) -->
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,16">
            <Label Content="Type" FontWeight="SemiBold"/>
            <ComboBox DockPanel.Dock="Top" x:Name="CboType"
                  materialDesign:HintAssist.Hint="Type"
                  SelectionChanged="CboType_SelectionChanged"
                  SelectedIndex="0" Margin="0,0,0,16">
                <ComboBoxItem Content="AI — Analog Input"/>
                <ComboBoxItem Content="AO — Analog Output"/>
                <ComboBoxItem Content="DI — Digital Input"/>
                <ComboBoxItem Content="DO — Digital Output"/>
                <ComboBoxItem Content="Alarm"/>
            </ComboBox>
        </StackPanel>

        <!-- Dugmad na dnu -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Add" Style="{StaticResource PrimaryButton}"
                    Click="BtnAdd_Click" Width="90"/>
            <Button Content="Cancel" Style="{StaticResource SecondaryButton}"
                    Click="BtnCancel_Click" Width="90" Margin="8,0,0,0"/>
        </StackPanel>

        <!-- Formular (skrolabilan) -->
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="FormPanel" Margin="0,0,0,8">

                <!-- ═══ Shared fields (all tag types) ════════════════════════ -->
                <StackPanel x:Name="PanelShared">
                    <Label Content="Tag Name *" FontWeight="SemiBold"/>
                    <TextBox x:Name="TxtName"
                             Margin="0,0,0,18"/>

                    <Label Content="Description"/>
                    <TextBox x:Name="TxtDescription"
                             Margin="0,0,0,18"/>

                    <!-- I/O Address is populated in code-behind based on tag type,
                         showing only valid + available addresses -->
                    <Label Content="I/O Address *" FontWeight="SemiBold"/>
                    <ComboBox x:Name="CboAddress"
                              Margin="0,0,0,18"/>
                </StackPanel>

                <!-- ═══ Input-tag fields (AI + DI) ═══════════════════════════ -->
                <StackPanel x:Name="PanelInput" Visibility="Visible">
                    <Label Content="Scan Time (ms) *" FontWeight="SemiBold"/>
                    <TextBox x:Name="TxtScanTime" Text="1000"
                             Margin="0,0,0,18"/>

                    <CheckBox x:Name="ChkScanEnabled" Content="Scan Enabled"
                              IsChecked="True" Margin="0,0,0,18"/>
                </StackPanel>

                <!-- ═══ Analog fields (AI + AO) ══════════════════════════════ -->
                <StackPanel x:Name="PanelAnalog" Visibility="Visible">
                    <Label Content="Low Limit *" FontWeight="SemiBold"/>
                    <TextBox x:Name="TxtLow" Text="0"
                             Margin="0,0,0,18"/>

                    <Label Content="High Limit *" FontWeight="SemiBold"/>
                    <TextBox x:Name="TxtHigh" Text="100"
                             Margin="0,0,0,18"/>

                    <Label Content="Units"/>
                    <TextBox x:Name="TxtUnits"
                             Margin="0,0,0,18"/>
                </StackPanel>

                <!-- ═══ AI-only fields (Deadband + Hysteresis) ═══════════════ -->
                <StackPanel x:Name="PanelAiOnly" Visibility="Visible">
                    <Label Content="Deadband *" FontWeight="SemiBold"/>
                    <TextBox x:Name="TxtDeadband" Text="0"
                             Margin="0,0,0,18"/>

                    <Label Content="Hysteresis *" FontWeight="SemiBold"/>
                    <TextBox x:Name="TxtHysteresis" Text="0"
                             Margin="0,0,0,18"/>
                </StackPanel>

                <!-- ═══ Output initial value (AO + DO) ═══════════════════════ -->
                <StackPanel x:Name="PanelOutput" Visibility="Collapsed">
                    <Label Content="Initial Value *" FontWeight="SemiBold"/>
                    <TextBox x:Name="TxtInitialValue" Text="0"
                             Margin="0,0,0,18"/>
                </StackPanel>

                <!-- ═══ Alarm-specific fields ═════════════════════════════════ -->
                <StackPanel x:Name="PanelAlarm" Visibility="Collapsed">
                    <Label Content="AI Tag Name *" FontWeight="SemiBold"/>
                    <ComboBox x:Name="CboAlarmTag"
                              Margin="0,0,0,18"/>

                    <Label Content="Limit Value *" FontWeight="SemiBold"/>
                    <TextBox x:Name="TxtAlarmLimit"
                             Margin="0,0,0,18"/>

                    <ComboBox x:Name="CboAlarmDir" SelectedIndex="0" Margin="0,0,0,18">
                        <ComboBoxItem Content="High — triggers when value exceeds limit"/>
                        <ComboBoxItem Content="Low — triggers when value drops below limit"/>
                    </ComboBox>

                    <Label Content="Alarm Message"/>
                    <TextBox x:Name="TxtAlarmMsg"
                             Margin="0,0,0,18"/>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>

    </DockPanel>
</Window>
