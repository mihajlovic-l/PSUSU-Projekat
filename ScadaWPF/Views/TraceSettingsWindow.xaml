<Window x:Class="ScadaWPF.Views.TraceSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Trace Settings" Height="540" Width="490"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource MaterialDesignPaper}"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        FontFamily="{materialDesign:MaterialDesignFont}">

    <DockPanel Margin="24">

        <!-- ── Header ─────────────────────────────────────────────────────────── -->
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,16">
            <TextBlock Text="Log Trace Settings"
                       FontSize="17" FontWeight="Medium"/>
        </StackPanel>

        <!-- ── Traceword display ───────────────────────────────────────────────── -->
        <materialDesign:Card DockPanel.Dock="Bottom" Padding="16,12" Margin="0,16,0,0"
                              UniformCornerRadius="4"
                              materialDesign:ElevationAssist.Elevation="Dp1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Decimal value -->
                <TextBlock Grid.Row="0" Grid.Column="0"
                           Text="Traceword (decimal)" FontSize="12"
                           Foreground="{DynamicResource MaterialDesignBodyLight}"
                           VerticalAlignment="Center"/>
                <TextBlock Grid.Row="0" Grid.Column="1"
                           Text="{Binding Traceword}"
                           FontSize="20" FontWeight="Medium"
                           HorizontalAlignment="Right"/>

                <!-- Binary representation -->
                <TextBlock Grid.Row="1" Grid.Column="0"
                           Text="Traceword (binary)" FontSize="12"
                           Foreground="{DynamicResource MaterialDesignBodyLight}"
                           VerticalAlignment="Center" Margin="0,6,0,0"/>
                <TextBlock Grid.Row="1" Grid.Column="1"
                           Text="{Binding TracewordBinary}"
                           FontSize="14" FontFamily="Consolas"
                           Foreground="{DynamicResource MaterialDesignBody}"
                           HorizontalAlignment="Right" Margin="0,6,0,0"/>
            </Grid>
        </materialDesign:Card>

        <!-- ── Checkboxes ─────────────────────────────────────────────────────── -->
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!--
                    Each CheckBox.IsChecked binds two-way to a bool property in
                    TraceSettingsViewModel. Changing the checkbox instantly calls
                    Logger.SetBit and persists the new traceword to disk.
                -->

                <!-- Bit 0 -->
                <materialDesign:Card Padding="12,8" Margin="0,0,0,8" UniformCornerRadius="4"
                                      materialDesign:ElevationAssist.Elevation="Dp1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="60"/>
                        </Grid.ColumnDefinitions>
                        <CheckBox Grid.Column="0" VerticalAlignment="Center"
                                  IsChecked="{Binding LoginEnabled, Mode=TwoWay}"/>
                        <StackPanel Grid.Column="1" Margin="10,0,0,0">
                            <TextBlock Text="Login" FontWeight="Medium" FontSize="13"/>
                            <TextBlock Text="Application start/stop"
                                       FontSize="11" Foreground="{DynamicResource MaterialDesignBodyLight}"/>
                        </StackPanel>
                        <materialDesign:Chip Grid.Column="2" Content="bit 0"
                                              VerticalAlignment="Center"
                                              FontFamily="Consolas" FontSize="10"/>
                    </Grid>
                </materialDesign:Card>

                <!-- Bit 1 -->
                <materialDesign:Card Padding="12,8" Margin="0,0,0,8" UniformCornerRadius="4"
                                      materialDesign:ElevationAssist.Elevation="Dp1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="60"/>
                        </Grid.ColumnDefinitions>
                        <CheckBox Grid.Column="0" VerticalAlignment="Center"
                                  IsChecked="{Binding AlarmAckEnabled, Mode=TwoWay}"/>
                        <StackPanel Grid.Column="1" Margin="10,0,0,0">
                            <TextBlock Text="Alarm Acknowledge" FontWeight="Medium" FontSize="13"/>
                            <TextBlock Text="User acknowledged an alarm"
                                       FontSize="11" Foreground="{DynamicResource MaterialDesignBodyLight}"/>
                        </StackPanel>
                        <materialDesign:Chip Grid.Column="2" Content="bit 1"
                                              VerticalAlignment="Center"
                                              FontFamily="Consolas" FontSize="10"/>
                    </Grid>
                </materialDesign:Card>

                <!-- Bit 2 -->
                <materialDesign:Card Padding="12,8" Margin="0,0,0,8" UniformCornerRadius="4"
                                      materialDesign:ElevationAssist.Elevation="Dp1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="60"/>
                        </Grid.ColumnDefinitions>
                        <CheckBox Grid.Column="0" VerticalAlignment="Center"
                                  IsChecked="{Binding TagAddEnabled, Mode=TwoWay}"/>
                        <StackPanel Grid.Column="1" Margin="10,0,0,0">
                            <TextBlock Text="Tag Add / Remove" FontWeight="Medium" FontSize="13"/>
                            <TextBlock Text="Adding or removing tags/alarms"
                                       FontSize="11" Foreground="{DynamicResource MaterialDesignBodyLight}"/>
                        </StackPanel>
                        <materialDesign:Chip Grid.Column="2" Content="bit 2"
                                              VerticalAlignment="Center"
                                              FontFamily="Consolas" FontSize="10"/>
                    </Grid>
                </materialDesign:Card>

                <!-- Bit 3 -->
                <materialDesign:Card Padding="12,8" Margin="0,0,0,8" UniformCornerRadius="4"
                                      materialDesign:ElevationAssist.Elevation="Dp1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="60"/>
                        </Grid.ColumnDefinitions>
                        <CheckBox Grid.Column="0" VerticalAlignment="Center"
                                  IsChecked="{Binding UpdateEnabled, Mode=TwoWay}"/>
                        <StackPanel Grid.Column="1" Margin="10,0,0,0">
                            <TextBlock Text="Tag Update" FontWeight="Medium" FontSize="13"/>
                            <TextBlock Text="Tags parameters updated"
                                       FontSize="11" Foreground="{DynamicResource MaterialDesignBodyLight}"/>
                        </StackPanel>
                        <materialDesign:Chip Grid.Column="2" Content="bit 3"
                                              VerticalAlignment="Center"
                                              FontFamily="Consolas" FontSize="10"/>
                    </Grid>
                </materialDesign:Card>

                <!-- Bit 4 -->
                <materialDesign:Card Padding="12,8" Margin="0,0,0,8" UniformCornerRadius="4"
                                      materialDesign:ElevationAssist.Elevation="Dp1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="60"/>
                        </Grid.ColumnDefinitions>
                        <CheckBox Grid.Column="0" VerticalAlignment="Center"
                                  IsChecked="{Binding ImportExportEnabled, Mode=TwoWay}"/>
                        <StackPanel Grid.Column="1" Margin="10,0,0,0">
                            <TextBlock Text="Import / Export" FontWeight="Medium" FontSize="13"/>
                            <TextBlock Text="Config import/export and report generation"
                                       FontSize="11" Foreground="{DynamicResource MaterialDesignBodyLight}"/>
                        </StackPanel>
                        <materialDesign:Chip Grid.Column="2" Content="bit 4"
                                              VerticalAlignment="Center"
                                              FontFamily="Consolas" FontSize="10"/>
                    </Grid>
                </materialDesign:Card>

                <!-- Bit 5 -->
                <materialDesign:Card Padding="12,8" Margin="0,0,0,8" UniformCornerRadius="4"
                                      materialDesign:ElevationAssist.Elevation="Dp1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="60"/>
                        </Grid.ColumnDefinitions>
                        <CheckBox Grid.Column="0" VerticalAlignment="Center"
                                  IsChecked="{Binding AlarmRaisedEnabled, Mode=TwoWay}"/>
                        <StackPanel Grid.Column="1" Margin="10,0,0,0">
                            <TextBlock Text="Alarm Raised" FontWeight="Medium" FontSize="13"/>
                            <TextBlock Text="An alarm threshold was crossed"
                                       FontSize="11" Foreground="{DynamicResource MaterialDesignBodyLight}"/>
                        </StackPanel>
                        <materialDesign:Chip Grid.Column="2" Content="bit 5"
                                              VerticalAlignment="Center"
                                              FontFamily="Consolas" FontSize="10"/>
                    </Grid>
                </materialDesign:Card>

                <!-- Bit 6 -->
                <materialDesign:Card Padding="12,8" Margin="0,0,0,8" UniformCornerRadius="4"
                                      materialDesign:ElevationAssist.Elevation="Dp1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="60"/>
                        </Grid.ColumnDefinitions>
                        <CheckBox Grid.Column="0" VerticalAlignment="Center"
                                  IsChecked="{Binding TagWriteEnabled, Mode=TwoWay}"/>
                        <StackPanel Grid.Column="1" Margin="10,0,0,0">
                            <TextBlock Text="Write to Tag" FontWeight="Medium" FontSize="13"/>
                            <TextBlock Text="Value written to AO or DO tag"
                                       FontSize="11" Foreground="{DynamicResource MaterialDesignBodyLight}"/>
                        </StackPanel>
                        <materialDesign:Chip Grid.Column="2" Content="bit 6"
                                              VerticalAlignment="Center"
                                              FontFamily="Consolas" FontSize="10"/>
                    </Grid>
                </materialDesign:Card>

                <!-- Bit 7 — recommended always on, kept visually distinct via a warning-tinted card -->
                <materialDesign:Card Padding="12,8" Margin="0,0,0,8" UniformCornerRadius="4"
                                      materialDesign:ElevationAssist.Elevation="Dp1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="60"/>
                        </Grid.ColumnDefinitions>
                        <CheckBox Grid.Column="0" VerticalAlignment="Center"
                                  IsChecked="{Binding ErrorEnabled, Mode=TwoWay}"/>
                        <StackPanel Grid.Column="1" Margin="10,0,0,0">
                            <TextBlock Text="Errors / Exceptions" FontWeight="Medium" FontSize="13"/>
                            <TextBlock Text="Exception and error states"
                                       FontSize="11" Foreground="{DynamicResource MaterialDesignBodyLight}"/>
                        </StackPanel>
                        <materialDesign:Chip Grid.Column="2" Content="bit 7"
                                              VerticalAlignment="Center"
                                              FontFamily="Consolas" FontSize="10"/>
                    </Grid>
                </materialDesign:Card>

            </StackPanel>
        </ScrollViewer>

    </DockPanel>
</Window>
