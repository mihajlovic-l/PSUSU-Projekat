<Application x:Class="ScadaWPF.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             StartupUri="Views/MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- ── Material Design palette + control theme ───────────────────── -->
                <!-- PrimaryColor "Blue" keeps the app close to the previous #1A73E8 accent -->
                <materialDesign:BundledTheme BaseTheme="Light" PrimaryColor="Blue" SecondaryColor="Amber"/>
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign2.Defaults.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- ── Semantic status colours (alarm severity / destructive actions) ── -->
            <SolidColorBrush x:Key="DangerBrush"  Color="#D32F2F"/>
            <SolidColorBrush x:Key="WarningBrush" Color="#F9A825"/>
            <SolidColorBrush x:Key="SuccessBrush" Color="#388E3C"/>

            <!-- ── Buttons ─────────────────────────────────────────────────────── -->
            <!-- Primary action -> filled Material button (uses the primary palette colour) -->
            <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}"/>

            <!-- Secondary / less prominent action -> outlined Material button -->
            <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource MaterialDesignOutlinedButton}"/>

            <!-- Destructive action -> filled button recoloured to the danger palette -->
            <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
                <Setter Property="Background"  Value="{StaticResource DangerBrush}"/>
                <Setter Property="BorderBrush" Value="{StaticResource DangerBrush}"/>
                <Setter Property="Foreground"  Value="White"/>
            </Style>

            <!-- ── Compact GridView column headers ────────────────────────────────
                 The stock Material Design header style reserves a lot of horizontal
                 padding (meant for mouse-friendly touch targets), which crowds out
                 the header text on the narrow columns used by the tag/alarm grids.
                 This trims the padding and left-aligns the text so headers actually
                 fit their columns. ──────────────────────────────────────────────── -->
            <Style x:Key="CompactGridViewColumnHeader" TargetType="GridViewColumnHeader"
                   BasedOn="{StaticResource {x:Type GridViewColumnHeader}}">
                <Setter Property="Padding" Value="10,6,10,6"/>
                <Setter Property="FontSize" Value="11.5"/>
                <Setter Property="HorizontalContentAlignment" Value="Left"/>
            </Style>

        </ResourceDictionary>
    </Application.Resources>
</Application>
